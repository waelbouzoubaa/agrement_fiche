# ── Local dev (SQLite) ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./agrement.db
UPLOADS_DIR=./uploads

# ── Docker avec PostgreSQL ──────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:password@db:5432/agrement
# UPLOADS_DIR=/app/uploads

# ── Google Cloud Storage ────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
GCS_BUCKET=ramery-agrement
# Alternative : passer le JSON directement (utile pour secrets managers)
# GCS_CREDENTIALS_JSON={"type":"service_account",...}
